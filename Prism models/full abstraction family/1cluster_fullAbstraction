endmodule

module Hardware
  hw_state : [0..1] init 0;

  // Can be updated via some sync or monitoring
  [update_hw] hw_state=0 & task_counter<=2 & (s1> sensors & s1< task_failed) 
-> (hw_state'=1);

  [reset_hw] hw_state>0& task_counter<=2  &  (s1> task_failed ) -> (hw_state'=0);
endmodule


// Environment sensing: 0 = idle, 1 = MIC, 2 = ACC, 3 = BOTH
module Environment
  sound :[0..1] init 0;
  move :[0..1] init 0;
  env_state1 : [0..1] init 0;


  [sound_on] sound=0 & task_counter<2 &s1!=start_task & (env_state1=1)-> (sound'=1);
  [move_on] move=0 & task_counter<2  &s1!=start_task & (env_state1=1) -> (move'=1);
  [sound_off] sound=1 & task_counter<2  &s1!=start_task & (env_state1=1) -> (sound'=0);
  [move_off] move=1& task_counter<2  &s1!=start_task & (env_state1=1)-> (move'=0);

  [sense1] s1=start_task & env_state1!=1  -> (env_state1'=1);
 


// add more syncing action per module yet after detecting you might take action upon the full system or
//or partially per module
  [reset_env1] env_state1!=0  & (s1=finish | s1=task_failed)& task_counter<2-> (env_state1'=0);

endmodule

