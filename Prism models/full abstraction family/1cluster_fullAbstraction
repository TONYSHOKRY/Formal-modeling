// Constants for states
const int idle = 0;// 
const int start_task = 1;
const int choose_Red = 2;
const int choose_white = 3;
const int sensors = 4;
const int pitch_on = 5;
const int pitch_off = 6;
const int high_blink_high_buzz = 7;
const int med_blink_med_buzz = 8;
const int high_Led = 9;
const int low_Led = 10;
const int task_failed = 11;
const int finish = 12;

module Operator
staggered:bool init false;//means it is concurrently working
//[Do_staggered] staggered=false & s1=idle & s2=idle ->(staggered'=true);
endmodule

module pattern
Rec_motif1:bool init false;//means it is line pattern
//Rec_motif2:bool init false;//means it is line pattern
//Rec_motif3:bool init false;//means it is line pattern
[Rec_1]Rec_motif1=false & s1=idle & task_counter=0  ->(Rec_motif1'=true);
