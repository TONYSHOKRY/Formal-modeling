///////////////////////////////////


 // Start task (guarded by active1)
  [stag1] s1=start_task  & staggered=true&turn=0&stagcounter=false -> (s1'=choose_Red) & (color1'=1) ;
  [stag1] s1=start_task & staggered=true&turn=0&stagcounter=false -> (s1'=choose_white) & (color1'=2) ;

  [stag1] s1=start_task  & staggered=true&turn=0&stagcounter=false-> (s1'=pitch_on) ;


  [sense1] s1=start_task & staggered=true&turn=0&stagcounter=false -> (s1'=sensors) ;


  // Color selection
  [stag1] s1=choose_Red & staggered=true&turn=0-> (s1'=high_blink_high_buzz)  ;
  [stag1] s1=choose_Red & staggered=true&turn=0-> (s1'=med_blink_med_buzz) ;
  [stag1] s1=choose_Red & staggered=true&turn=0-> (s1'=high_Led) ;
  [stag1] s1=choose_Red & staggered=true&turn=0-> (s1'=low_Led) ;

  [stag1] s1=choose_white & staggered=true&turn=0-> (s1'=high_blink_high_buzz)  ;
  [stag1] s1=choose_white & staggered=true&turn=0-> (s1'=med_blink_med_buzz) ;
  [stag1] s1=choose_white & staggered=true&turn=0-> (s1'=high_Led) ;
  [stag1] s1=choose_white & staggered=true&turn=0-> (s1'=low_Led) ;

////////////////////////////////////
  // Probabilistic transitions (BB1-specific) LINE pattern syncroninzed with other clusters
///////////////////////////////////
//pitch
  [stag1] s1=pitch_on & (hw_state=1 |(move=1 & env_state1=0)) & Rec_motif1=false & staggered=true&turn=0 -> (s1'=pitch_off); // Priority 1: hardware HIGH,move -> immediate shutdown
  [stag1] s1=pitch_on & (hw_state=0 & env_state1=1)&(sound=1 | move=1) & Rec_motif1=false & staggered=true&turn=0 ->  0.5 : (s1'=finish) + 0.5: (s1'=pitch_off); // environment
  [stag1] s1=pitch_on & (hw_state=0 & env_state1=0) & Rec_motif1=false & staggered=true&turn=0 ->  q_high_pitch_c1 : (s1'=finish) + 1-q_high_pitch_c1: (s1'=task_failed); // Baseline

  [stag1] s1=pitch_off & env_state1=1 &(move=1 | sound=1 ) & Rec_motif1=false & staggered=true&turn=0 -> (s1'=pitch_on); // Dynamic adaptation
  [stag1] s1=pitch_off & env_state1=0 & Rec_motif1=false & staggered=true&turn=0 -> (s1'=finish); 

//sensor-environment transition
  [stag1] s1=sensors & Rec_motif1=false & staggered=true&turn=0->  (s1'=finish); 


//high-high simultaneous actuating white

  [stag1] s1=high_blink_high_buzz &color1=2 & (hw_state=1) & Rec_motif1=false & staggered=true&turn=0 -> (s1'=med_blink_med_buzz);// Priority : hardware MED -> reduce one level
  [stag1] s1=high_blink_high_buzz &color1=2 & hw_state=0 & env_state1=0  & move=1& Rec_motif1=false & staggered=true&turn=0
->(q_w_high_c1*gamma)*q_high_pitch_c1:(s1'=task_failed) + 1-((q_w_high_c1*gamma)*q_high_pitch_c1): (s1'=finish);// when move (no direct intention of fallback), chance of failure occurs
  [stag1] s1=high_blink_high_buzz &color1=2 & hw_state=0 & env_state1=1  & (sound=1 |move=1)& Rec_motif1=false & staggered=true&turn=0
->(q_w_high_c1*gamma)*q_high_pitch_c1 : (s1'=med_blink_med_buzz) + 1-((q_w_high_c1*gamma)*q_high_pitch_c1) : (s1'=finish);
  [stag1] s1=high_blink_high_buzz &color1=2 & hw_state=0  & move=0 & Rec_motif1=false & staggered=true&turn=0 
-> (q_w_high_c1*gamma)*q_high_pitch_c1: (s1'=finish) + (1-((q_w_high_c1*gamma)*q_high_pitch_c1)): (s1'=task_failed);
//high-high simultaneous actuating RED
 
  [stag1] s1=high_blink_high_buzz &color1=1 & (hw_state=1) & Rec_motif1=false & staggered=true&turn=0 -> (s1'=med_blink_med_buzz);// Priority 2: hardware MED -> reduce one level
  [stag1] s1=high_blink_high_buzz &color1=1 & hw_state=0 & env_state1=0  & move=1& Rec_motif1=false & staggered=true&turn=0
->(q_r_high_c1*gamma)*q_high_pitch_c1:(s1'=task_failed) + 1-((q_r_high_c1*gamma)*q_high_pitch_c1): (s1'=finish);// when move (no direct intention of fallback), chance of failure occurs
  [stag1] s1=high_blink_high_buzz &color1=1 & hw_state=0 & env_state1=1  & (sound=1 |move=1)& Rec_motif1=false & staggered=true&turn=0
->(q_r_high_c1*gamma)*q_high_pitch_c1 : (s1'=med_blink_med_buzz) + 1-((q_r_high_c1*gamma)*q_high_pitch_c1) : (s1'=finish);
  [stag1] s1=high_blink_high_buzz &color1=1 & hw_state=0  & move=0 & Rec_motif1=false & staggered=true&turn=0 
-> (q_r_high_c1*gamma)*q_high_pitch_c1: (s1'=finish) + (1-((q_r_high_c1*gamma)*q_high_pitch_c1)): (s1'=task_failed);


