  [step] s2=pitch_on & (hw_state=1 |(move=1 & env_state2=0)) & Rec_motif2=false & staggered=false -> (s2'=pitch_off); // Priority 1: hardware HIGH,move -> immediate shutdown
  [step] s2=pitch_on & (hw_state=0 & env_state2=1)&(sound=1 | move=1) & Rec_motif2=false & staggered=false ->  0.5 : (s2'=finish) + 0.5: (s2'=pitch_off); // environment
  [step] s2=pitch_on & (hw_state=0 & env_state2=0) & Rec_motif2=false & staggered=false ->  q_high_pitch_c1 : (s2'=finish) + 1-q_high_pitch_c1: (s2'=task_failed); // Baseline

  [step] s2=pitch_off & env_state2=1 &(move=1 | sound=1 ) & Rec_motif2=false & staggered=false -> (s2'=pitch_on); // Dynamic adaptation
  [step] s2=pitch_off & env_state2=0 & Rec_motif2=false & staggered=false -> (s2'=finish); 

//sensor-environment transition
  [step] s2=sensors & Rec_motif2=false & staggered=false->  (s2'=finish); 


//high-high simultaneous actuating white

  [step] s2=high_blink_high_buzz &color2=2 & (hw_state=1) & Rec_motif2=false & staggered=false -> (s2'=med_blink_med_buzz);// Priority : hardware MED -> reduce one level
  [step] s2=high_blink_high_buzz &color2=2 & hw_state=0 & env_state2=0  & move=1& Rec_motif2=false & staggered=false
->(q_w_high_c1*alpha2)*q_high_pitch_c1:(s2'=task_failed) + 1-((q_w_high_c1*alpha2)*q_high_pitch_c1): (s2'=finish);// when move (no direct intention of fallback), chance of failure occurs
  [step] s2=high_blink_high_buzz &color2=2 & hw_state=0 & env_state2=1  & (sound=1 |move=1)& Rec_motif2=false & staggered=false
->(q_w_high_c1*alpha2)*q_high_pitch_c1 : (s2'=med_blink_med_buzz) + 1-((q_w_high_c1*alpha2)*q_high_pitch_c1) : (s2'=finish);
  [step] s2=high_blink_high_buzz &color2=2 & hw_state=0 & move=0 & Rec_motif2=false & staggered=false 
-> (q_w_high_c1*alpha2)*q_high_pitch_c1: (s2'=finish) + (1-((q_w_high_c1*alpha2)*q_high_pitch_c1)): (s2'=task_failed);
//high-high simultaneous actuating RED
 
