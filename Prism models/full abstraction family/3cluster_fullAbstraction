module Task_Controller
  task_counter : [0..2] init 0;
  //active1 : bool init true;
 // active2 : bool init true;
 // active3 : bool init true;
 stagcounter : bool init false;
 turn: [0..2] init 0;// depends on number of clusters in here 2 modules

  //[activate_1] (s1=idle&s2=idle&s3=idle) & !active1 & task_counter=0 -> (active1'=true);
  //[activate_2] (s1=idle&s2=idle&s3=idle) & !active2 & task_counter=0 -> (active2'=true);
  //[activate_3] (s1=idle&s2=idle&s3=idle) & !active3 & task_counter=0 -> (active3'=true);
  
