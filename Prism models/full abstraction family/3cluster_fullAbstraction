  //[deactivate_2] (s1=idle&s2=idle&s3=idle) & active2 -> (active2'=false);
  

    [Task_increment] task_counter<2 & staggered=false&
        ( (s1=finish | s1=task_failed)| 
         (s2=finish | s2=task_failed) | 
         (s3=finish | s3=task_failed))->
         (task_counter'=task_counter+1) ;


[turn1] turn=0 & (s1=finish|s1=task_failed) & staggered=true-> (turn'=1);
[turn2] turn=1 & (s2=finish|s2=task_failed) & staggered=true-> (turn'=2);
[turn3] turn=2 & (s3=finish|s3=task_failed) & staggered=true &stagcounter=false-> (turn'=0)&(stagcounter'=true);

[Task_increment_stag] task_counter<2& (s3=start_task) & staggered=true& stagcounter=true -> (task_counter'=task_counter+1)&(stagcounter'=false);
endmodule




// BB1: Cluster 1 of Blinky Blocks
module c1
  s1 : [0..12] init idle;
  color1 : [0..2] init 0;
//to reduce state explosion and to avoid non determinism from the beginning of the model
  [] (s1=idle) -> (s1'=start_task) ;

  // Start task (guarded by active1)
  [step] s1=start_task  & staggered=false -> (s1'=choose_Red) & (color1'=1) ;
  [step] s1=start_task & staggered=false -> (s1'=choose_white) & (color1'=2) ;

  [step] s1=start_task & staggered=false-> (s1'=pitch_on) ;


  [sense1] s1=start_task & staggered=false -> (s1'=sensors) ;


  // Color selection
  [step] s1=choose_Red & staggered=false-> (s1'=high_blink_high_buzz)  ;
  [step] s1=choose_Red & staggered=false-> (s1'=med_blink_med_buzz) ;
  [step] s1=choose_Red & staggered=false-> (s1'=high_Led) ;
  [step] s1=choose_Red & staggered=false-> (s1'=low_Led) ;

  [step] s1=choose_white & staggered=false-> (s1'=high_blink_high_buzz)  ;
  [step] s1=choose_white & staggered=false-> (s1'=med_blink_med_buzz) ;
  [step] s1=choose_white & staggered=false-> (s1'=high_Led) ;
  [step] s1=choose_white & staggered=false-> (s1'=low_Led) ;

////////////////////////////////////
  // Probabilistic transitions (BB1-specific) LINE pattern syncroninzed with other clusters
///////////////////////////////////
//pitch
  [step] s1=pitch_on & (hw_state=1 |(move=1 & env_state1=0)) & Rec_motif1=false & staggered=false -> (s1'=pitch_off); // Priority 1: hardware HIGH,move -> immediate shutdown
  [step] s1=pitch_on & (hw_state=0 & env_state1=1)&(sound=1 | move=1) & Rec_motif1=false & staggered=false ->  0.5 : (s1'=finish) + 0.5: (s1'=pitch_off); // environment
  [step] s1=pitch_on & (hw_state=0 & env_state1=0) & Rec_motif1=false & staggered=false ->  q_high_pitch_c1 : (s1'=finish) + 1-q_high_pitch_c1: (s1'=task_failed); // Baseline

  [step] s1=pitch_off & env_state1=1 &(move=1 | sound=1 ) & Rec_motif1=false & staggered=false -> (s1'=pitch_on); // Dynamic adaptation
  [step] s1=pitch_off & env_state1=0 & Rec_motif1=false & staggered=false -> (s1'=finish); 

//sensor-environment transition
  [step] s1=sensors & Rec_motif1=false & staggered=false->  (s1'=finish); 


//high-high simultaneous actuating white

  [step] s1=high_blink_high_buzz &color1=2 & (hw_state=1) & Rec_motif1=false & staggered=false -> (s1'=med_blink_med_buzz);// Priority : hardware MED -> reduce one level
  [step] s1=high_blink_high_buzz &color1=2 & hw_state=0 & env_state1=0  & move=1& Rec_motif1=false & staggered=false
->q_w_high_c1*q_high_pitch_c1:(s1'=task_failed) + 1-(q_w_high_c1*q_high_pitch_c1): (s1'=finish);// when move (no direct intention of fallback), chance of failure occurs
  [step] s1=high_blink_high_buzz &color1=2 & hw_state=0 & env_state1=1  & (sound=1 |move=1)& Rec_motif1=false & staggered=false
->q_w_high_c1*q_high_pitch_c1 : (s1'=med_blink_med_buzz) + 1-(q_w_high_c1*q_high_pitch_c1) : (s1'=finish);
  [step] s1=high_blink_high_buzz &color1=2 & hw_state=0 & move=0 & Rec_motif1=false & staggered=false 
-> q_w_high_c1*q_high_pitch_c1: (s1'=finish) + (1-(q_w_high_c1*q_high_pitch_c1)): (s1'=task_failed);
//high-high simultaneous actuating RED
 
  [step] s1=high_blink_high_buzz &color1=1 & (hw_state=1) & Rec_motif1=false & staggered=false -> (s1'=med_blink_med_buzz);// Priority 2: hardware MED -> reduce one level
  [step] s1=high_blink_high_buzz &color1=1 & hw_state=0 & env_state1=0  & move=1& Rec_motif1=false & staggered=false
->q_r_high_c1*q_high_pitch_c1:(s1'=task_failed) + 1-(q_r_high_c1*q_high_pitch_c1): (s1'=finish);// when move (no direct intention of fallback), chance of failure occurs
  [step] s1=high_blink_high_buzz &color1=1 & hw_state=0 & env_state1=1  & (sound=1 |move=1)& Rec_motif1=false & staggered=false
->q_r_high_c1*q_high_pitch_c1 : (s1'=med_blink_med_buzz) + 1-(q_r_high_c1*q_high_pitch_c1) : (s1'=finish);
  [step] s1=high_blink_high_buzz &color1=1 & hw_state=0  & move=0 & Rec_motif1=false & staggered=false 
-> q_r_high_c1*q_high_pitch_c1: (s1'=finish) + (1-(q_r_high_c1*q_high_pitch_c1)): (s1'=task_failed);


