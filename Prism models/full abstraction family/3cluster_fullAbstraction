  [step] s1=med_blink_med_buzz &color1=2& hw_state=0& Rec_motif1=false & staggered=false-> (q_w_high_c1*q_high_pitch_c1*beta) : (s1'=finish) + 1-(q_w_high_c1*q_high_pitch_c1*beta) : (s1'=task_failed);//empirical data

