// Constants for states
const int idle = 0;// 
const int start_task = 1;
const int choose_Red = 2;
const int choose_white = 3;
const int sensors = 4;
const int pitch_on = 5;
const int pitch_off = 6;
const int high_blink_high_buzz = 7;
const int med_blink_med_buzz = 8;
const int high_Led = 9;
const int low_Led = 10;
const int task_failed = 11;
const int finish = 12;

module Operator
staggered:bool init false;//means it is concurrently working
[Do_staggered] staggered=false & s1=idle & s2=idle & s3=idle ->(staggered'=true);
endmodule

module pattern
Rec_motif1:bool init false;//means it is line pattern
Rec_motif2:bool init false;//means it is line pattern
Rec_motif3:bool init false;//means it is line pattern
[Rec_1]Rec_motif1=false & s1=idle & task_counter=0  ->(Rec_motif1'=true);
[Rec_2]Rec_motif2=false & s2=idle & task_counter=0->(Rec_motif2'=true);
[Rec_3]Rec_motif3=false & s3=idle& task_counter=0 ->(Rec_motif3'=true);
endmodule

module Hardware
  hw_state : [0..1] init 0;

  // Can be updated via some sync or monitoring
  [update_hw] hw_state=0 & task_counter<=2 & (s1> sensors & s1< task_failed) 
& (s2> sensors & s2< task_failed) & (s3> sensors & s3< task_failed) -> (hw_state'=1);

  [reset_hw] hw_state>0& task_counter<=2  &  (s1> task_failed & s2> task_failed& s3> task_failed) -> (hw_state'=0);
endmodule


// Environment sensing: 0 = idle, 1 = MIC, 2 = ACC, 3 = BOTH
module Environment
  sound :[0..1] init 0;
  move :[0..1] init 0;
  env_state1 : [0..1] init 0;
 env_state2 : [0..1] init 0;
 env_state3 : [0..1] init 0;

 [sound_on] sound=0 & task_counter<2 & (s1> sensors & s1< task_failed) 
& (s2> sensors & s2< task_failed) & (s3> sensors & s3< task_failed)-> (sound'=1);
  [move_on] move=0 & task_counter<2  & (s1> sensors & s1< task_failed) 
& (s2> sensors & s2< task_failed) & (s3> sensors & s3< task_failed) -> (move'=1);
  [sound_off] sound=1 & task_counter<2  & (s1> sensors & s1< task_failed) 
& (s2> sensors & s2< task_failed) & (s3> sensors & s3< task_failed) -> (sound'=0);
  [move_off] move=1& task_counter<2  & (s1> sensors & s1< task_failed) 
& (s2> sensors & s2< task_failed) & (s3> sensors & s3< task_failed)-> (move'=0);

[sense1] s1=start_task & env_state1!=1  -> (env_state1'=1);
 
[sense2] s2=start_task & env_state2!=1  -> (env_state2'=1);

[sense3] s3=start_task & env_state3!=1  -> (env_state3'=1);
// add more syncing action per module yet after detecting you might take action upon the full system or
//or partially per module
[reset_env1] env_state1!=0  & (s1=finish | s1=task_failed)& task_counter<2-> (env_state1'=0);
[reset_env2] env_state2!=0  & (s2=finish | s2=task_failed)& task_counter<2-> (env_state2'=0);
[reset_env3] env_state3!=0  & (s3=finish | s3=task_failed)& task_counter<2-> (env_state3'=0);
endmodule

